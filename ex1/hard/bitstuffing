#include<stdio.h>
#define MAX 100
void displayBits(int arr[], int n)
{
   int i;
   for(i = 0; i < n; i++)
      printf("%d", arr[i]);
   printf("\n");
}
int main()
{
   int data[MAX], stuffed[MAX], framed[MAX], destuffed[MAX];
   int n, i, j, f, k, ones;
   int flag[] = {0, 1, 1, 1, 1, 1, 1, 0};
   printf("Enter the no of bits: ");
   scanf("%d", &n);
   printf("Enter the bits (0s and 1s):\n");
   for(i = 0; i < n; i++)
   {
      scanf("%d", &data[i]);
   }
   printf("\nOriginal data:  ");
   displayBits(data, n);
   ones = 0;
   j = 0;
   for(i = 0; i < n; i++)
   {
      stuffed[j++] = data[i];
      if(data[i] == 1)
         ones++;
      else
         ones = 0;
      if(ones == 5)
      {
         stuffed[j++] = 0;
         ones = 0;  
      }
   }
   printf("Stuffed data:   ");
   displayBits(stuffed, j);
   f = 0;
   for(i = 0; i < 8; i++) {
      framed[f++] = flag[i];
   }
   for(i = 0; i < j; i++) {
      framed[f++] = stuffed[i];
   }
   for(i = 0; i < 8; i++) {
      framed[f++] = flag[i];
   }
   printf("Framed data:    ");
   displayBits(framed, f);
   ones = 0;
   k = 0;
   for(i = 8; i < f - 8; i++)
   {
      destuffed[k++] = framed[i];
      if(framed[i] == 1)
         ones++;
      else
         ones = 0;
      if(ones == 5)
      {
         i++;
         ones = 0; 
      }
   }
   printf("Destuffed Data: ");
   displayBits(destuffed, k);
   return 0;
}
